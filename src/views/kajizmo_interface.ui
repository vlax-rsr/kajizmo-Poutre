  <property name="styleSheet">
   <string notr="true">/* ============================================================================
   KAJIZMO - Stylesheet Amélioré (Version Corrigée)
   Design moderne avec couleurs professionnelles et typographie cohérente
   ============================================================================ */

/* VARIABLE DE COULEUR PRINCIPALE POUR UN UNIFICATION MAXIMALE */
QWidget {
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, sans-serif;
    font-size: 13px;
    color: #1F2937;
    background-color: transparent;
}

/* ============================================================================
   FENÊTRES ET CONTAINERS DE BASE
   ============================================================================ */

QMainWindow, QDialog {
    background-color: #F5F7FA;
}

/* ============================================================================
   GROUPBOX - Conteneurs principaux avec titres améliorés
   ============================================================================ */

QGroupBox {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    margin-top: 10px;
    padding: 10px;
    font-weight: 600;
    font-size: 14px;
    color: #0F172A;
}

QGroupBox:hover {
    border: 1px solid #CBD5E1;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top center;
    left: 0px;
    top: 0px;
    padding: 0px 8px;
    background-color: #FFFFFF;
    color: #0F172A;
}

QGroupBox.Section::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 5px;
    top: 14px;
    padding: 0px 8px;
    background-color: #FFFFFF;
    color: #0F172A;
}

/* ============================================================================
   LABELS - Texte et étiquettes
   ============================================================================ */

QLabel {
    color: #334155;
    font-size: 13px;
    padding: 2px 0px;
    background-color: transparent;
}

QLabel.TitreResultat {
    color: #0F172A;
    font-size: 13px;
    padding: 6px 0px;
}

QLabel.Unite {
    color: #94A3B8;
    font-size: 12px;
    font-weight: 500;
}

QLabel#ResultatValide, QLabel#LabelValide, .SuccessText {
    color: #15803D;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.3px;
}

QLabel#ResultatErreur, QLabel#LabelErreur, .ErrorText {
    color: #B91C1C;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.3px;
}

/* ============================================================================
   CHAMPS D'ENTRÉE ET DE RÉSULTAT
   ============================================================================ */

QLineEdit, QPlainTextEdit, QSpinBox, QDoubleSpinBox, QTextEdit, QTextBrowser, QComboBox {
    background-color: #FFFFFF;
    color: #1F2937;
    border: 1.5px solid #E2E8F0;
    border-radius: 6px;
    padding: 8px 12px;
    font-family: &quot;Inter&quot;, &quot;Segoe UI&quot;, monospace;
    font-size: 13px;
    selection-background-color: #DBEAFE;
    selection-color: #1E293B;
}

QLineEdit:hover, QPlainTextEdit:hover, QSpinBox:hover, QDoubleSpinBox:hover, QTextEdit:hover, QTextBrowser:hover, QComboBox:hover {
    border: 1.5px solid #CBD5E1;
    background-color: #F8FAFC;
}

QLineEdit:focus, QPlainTextEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus, QTextEdit:focus, QTextBrowser:focus, QComboBox:focus, QComboBox:on {
    border: 2px solid #3B82F6;
    background-color: #F8FAFC;
    padding: 7px 11px;
}

QLineEdit:disabled, QPlainTextEdit:disabled, QSpinBox:disabled, QDoubleSpinBox:disabled, QTextEdit:disabled, QTextBrowser:disabled, QComboBox:disabled {
    background-color: #F1F5F9;
    color: #94A3B8;
    border: 1px solid #E2E8F0;
}

/* ============================================================================
   SPINBOX - BOUTONS ET FLÈCHES GARDÉS ET CORRIGÉS
   ============================================================================ */

QSpinBox::up-button, QDoubleSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 18px;
    border-left: 1px solid #CBD5E1;
    border-bottom: 1px solid #E2E8F0;
    background-color: #F8FAFC;
    border-top-right-radius: 6px;
}

QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover {
    background-color: #E2E8F0;
}

QSpinBox::down-button, QDoubleSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 18px;
    border-left: 1px solid #CBD5E1;
    background-color: #F8FAFC;
    border-bottom-right-radius: 6px;
}

QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #E2E8F0;
}

/* Conservation de tes icônes d'origine pour les flèches haut/bas */
QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    image: url(&quot;assets/icons/spin_up.svg&quot;);
    width: 8px;
    height: 6px;
}

QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    image: url(&quot;assets/icons/spin_down.svg&quot;);
    width: 8px;
    height: 6px;
}

/* ============================================================================
   COMBOBOX
   ============================================================================ */

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 20px;
    border-left: 1px solid #E2E8F0;
}

QComboBox::down-arrow {
    image: url(&quot;assets/icons/spin_down.svg&quot;); /* Réutilisation de ton icône descendante */
    width: 8px;
    height: 6px;
}

QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    color: #1F2937;
    border: 1px solid #CBD5E1;
    border-radius: 6px;
    selection-background-color: #DBEAFE;
    selection-color: #1E40AF;
    outline: none;
    padding: 4px;
}

/* ============================================================================
   BUTTONS
   ============================================================================ */

QPushButton {
    background-color: #F1F5F9;
    color: #1F2937;
    border: 1.5px solid #E2E8F0;
    border-radius: 8px;
    padding: 10px 18px;
    font-weight: 500;
    outline: none;
}

QPushButton:hover {
    background-color: #E2E8F0;
    border: 1.5px solid #CBD5E1;
}

QPushButton:pressed {
    background-color: #CBD5E1;
}

/* Style appliqué aux boutons intérieurs (ex: &quot;Armatures longitudinales&quot;) */
QGroupBox QPushButton {
    background-color: #3B82F6;
    color: #FFFFFF;
    border: none;
    font-weight: 600;
    font-size: 13px;
    padding: 12px 20px;
    min-height: 40px;
}

QGroupBox QPushButton:hover {
    background-color: #2563EB;
}

QPushButton#ExportXLSX, QPushButton#ExportTXT {
    background-color: #FFFFFF;
    color: #475569;
    border: 1.5px solid #CBD5E1;
}

QPushButton#ExportXLSX:hover, QPushButton#ExportTXT:hover {
    background-color: #F1F5F9;
    border: 1.5px solid #94A3B8;
}

QPushButton.ResetButton {
    background-color: #F8FAFC;
    color: #DC2626;
    border: 1.5px solid #FECACA;
}

QPushButton.ResetButton:hover {
    background-color: #FEE2E2;
}

/* ============================================================================
   BARRE DE STATUT
   ============================================================================ */

QStatusBar {
    background-color: #FFFFFF;
    color: #475569;
    border-top: 1px solid #E2E8F0;
    padding: 6px 12px;
}

QGraphicsView {
    background-color: #F8FBFF;
    border: 1px solid #DDE5EF;
    border-radius: 8px;
}

/* Warning */
QLineEdit#Warning, QComboBox#Warning {
    border: 1.5px solid rgb(217, 119, 6);
    /* 0.06 correspond à environ 6% d'opacité, parfait pour un fond pastel très doux */
    background-color: rgba(217, 119, 6, 0.06); 
}

/* Erreur */
QLineEdit#ErreurEntree, QComboBox#ErreurEntree, QSpinBox#ErreurEntree {
    border: 1.5px solid rgb(220, 38, 38); /* Rouge sombre élégant (#DC2626) */
    /* 0.06 d'opacité pour un fond rouge pastel très doux, non agressif */
    background-color: rgba(220, 38, 38, 0.06); 
}

</string>
